#include <iostream>
#include <stdexcept>

class DynamicArray {
private:
    int* data;
    int size;
public:
    DynamicArray(int size) {
        if (size <= 0) throw std::invalid_argument("Неверный размер");
        this->size = size;
        data = new int[size];
    }

    ~DynamicArray() {
        delete[] data;
    }
    int get(int index) const {
        if (index < 0 || index >= size)
            throw std::out_of_range("Индекс вне диапазона");
        return data[index];
    }
    void set(int index, int value) {
        if (index < 0 || index >= size)
            throw std::out_of_range("Индекс вне диапазона");
        data[index] = value;
    }
    void resize(int newSize) {
        if (newSize <= 0) throw std::invalid_argument("Неверный размер");

        int* newData = new int[newSize]; // может бросить bad_alloc

        for (int i = 0; i < std::min(size, newSize); i++)
            newData[i] = data[i];
        delete[] data;
        data = newData;
        size = newSize;
    }
};
int main() {
    try {
        DynamicArray arr(3);
        arr.set(0, 10);
        arr.set(1, 20);

        std::cout << arr.get(1) << std::endl;

        arr.resize(5);
        arr.set(4, 50);

        std::cout << arr.get(4) << std::endl;
    }
    catch (const std::exception& e) {
        std::cout << "Ошибка: " << e.what() << std::endl;
    }
}

