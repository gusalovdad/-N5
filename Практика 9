#include <iostream>
#include <stdexcept>

class OverflowException : public std::exception {
public:
    const char* what() const noexcept override {
        return "Переполнение при умножении";
    }
};
double add(double a, double b) { return a + b; }
double sub(double a, double b) { return a - b; }
double mul(double a, double b) {
    if (a > 1e9 || b > 1e9) {
        throw OverflowException();
    }
    return a * b;
}
double divv(double a, double b) {
    if (b == 0) throw std::runtime_error("Деление на ноль");
    return a / b;
}
int main() {
    double a, b;
    char op;
    while (true) {
        std::cout << "Введите выражение (или x для выхода): ";
        std::cin >> a;
        if (std::cin.fail()) break;
        std::cin >> op >> b;
        try {
            switch (op) {
                case '+': std::cout << add(a, b); break;
                case '-': std::cout << sub(a, b); break;
                case '*': std::cout << mul(a, b); break;
                case '/': std::cout << divv(a, b); break;
                default: throw std::invalid_argument("Некорректная операция");
            }
            std::cout << std::endl;
        }
        catch (const std::exception& e) {
            std::cout << "Ошибка: " << e.what() << std::endl;
        }
    }
    return 0;
}

