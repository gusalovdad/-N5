#include <iostream>
#include <fstream>

class FileWrapper {
private:
    std::ofstream file;
public:
    FileWrapper(const std::string& name) {
        file.open(name);
        if (!file.is_open())
            throw std::runtime_error("Ошибка открытия файла");
        std::cout << "Файл открыт\n";
    }
    ~FileWrapper() {
        std::cout << "Файл закрыт\n";
        file.close();
    }
    void write(const std::string& data) {
        file << data << std::endl;
    }
};
class DatabaseConnection {
public:
    DatabaseConnection() {
        std::cout << "Подключение к БД\n";
    }
    ~DatabaseConnection() {
        std::cout << "Отключение от БД\n";
    }
    void query(const std::string&) {
        throw std::runtime_error("Ошибка запроса");
    }
};
void process() {
    FileWrapper file("test.txt");
    DatabaseConnection db;

    file.write("Hello");
    db.query("SELECT *");
}
int main() {
    try {
        process();
    }
    catch (const std::exception& e) {
        std::cout << "Ошибка: " << e.what() << std::endl;
    }
}
