#include <iostream>
#include <exception>
#include <string>
#include <vector>

class LibraryException : public std::exception {
protected:
    int errorCode;
    std::string message;
public:
    LibraryException(const std::string& msg, int code)
        : message(msg), errorCode(code) {
    }
    const char* what() const noexcept override {
        return message.c_str();
    }
    int getCode() const { return errorCode; }
};
class BookNotFoundException : public LibraryException {
public:
    BookNotFoundException(const std::string& isbn)
        : LibraryException("Книга не найдена: " + isbn, 1) {
    }
};
class BookAlreadyBorrowedException : public LibraryException {
public:
    BookAlreadyBorrowedException(const std::string& isbn)
        : LibraryException("Книга уже выдана: " + isbn, 2) {
    }
};
class ReaderNotFoundException : public LibraryException {
public:
    ReaderNotFoundException(int id)
        : LibraryException("Читатель не найден: " + std::to_string(id), 3) {
    }
};
class MaxBooksReachedException : public LibraryException {
public:
    MaxBooksReachedException(int id)
        : LibraryException("Превышен лимит книг у читателя: " + std::to_string(id), 4) {
    }
};
class InvalidReturnDateException : public LibraryException {
public:
    InvalidReturnDateException()
        : LibraryException("Некорректная дата возврата", 5) {
    }
};
class Library {
public:
    void borrowBook(std::string isbn, int readerId) {
        if (isbn == "0") throw BookNotFoundException(isbn);
        if (isbn == "1") throw BookAlreadyBorrowedException(isbn);
        if (readerId == -1) throw ReaderNotFoundException(readerId);
        if (readerId > 5) throw MaxBooksReachedException(readerId);

        std::cout << "Книга выдана\n";
    }
};
int main() {
    Library lib;

    try {
        lib.borrowBook("1", 2);
    }
    catch (const LibraryException& e) {
        std::cout << "Ошибка: " << e.what()
            << " Код: " << e.getCode() << std::endl;
    }
}

