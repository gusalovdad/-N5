#include <iostream>
#include <stdexcept>

class SafeStack {
private:
    int* arr;
    int capacity;
    int size;
public:
    SafeStack() {
        capacity = 2;
        size = 0;
        arr = new int[capacity];
    }
    ~SafeStack() {
        delete[] arr;
    }
    void push(int x) {
        if (size == capacity) {
            capacity = capacity * 2;
            int* temp = new int[capacity];

            for (int i = 0; i < size; i++) {
                temp[i] = arr[i];
            }
            delete[] arr;
            arr = temp;
        }
        arr[size] = x;
        size++;
    }
    void pop() {
        if (size == 0) {
            throw std::out_of_range("Стек пуст");
        }
        size--;
    }
    int top() {
        if (size == 0) {
            throw std::out_of_range("Стек пуст");
        }
        return arr[size - 1];
    }
};

int main() {
    SafeStack st;
    try {
        st.push(5);
        st.push(15);
        std::cout << "Верхний элемент: " << st.top() << std::endl;
        st.pop();
        st.pop();
        st.pop();
    }
    catch (std::exception& e) {
        std::cout << "Ошибка: " << e.what() << std::endl;
    }
    return 0;
}

