#include <iostream>
#include <vector>
#include <string>

// базовое исключение
class MyException : public std::exception {
protected:
    std::string text;

public:
    MyException(std::string t) {
        text = t;
    }
    const char* what() const noexcept {
        return text.c_str();
    }
};
class NoConcert : public MyException {
public:
    NoConcert() : MyException("Концерт не найден") {}
};
class NoSeats : public MyException {
public:
    NoSeats() : MyException("Нет мест") {}
};
class PayError : public MyException {
public:
    PayError() : MyException("Ошибка оплаты") {}
};

struct Concert {
    std::string name;
    int total;
    int free;
    double price;
};


class System {
private:
    std::vector<Concert> list;

public:
    void add(std::string name, int seats, double price) {
        Concert c;
        c.name = name;
        c.total = seats;
        c.free = seats;
        c.price = price;

        list.push_back(c);
    }
    int find(std::string name) {
        for (int i = 0; i < list.size(); i++) {
            if (list[i].name == name)
                return i;
        }
        throw NoConcert();
    }
    void pay() {
        throw PayError(); // специально
    }
    void book(std::string name, int count) {
        int i = find(name);
        if (list[i].free < count)
            throw NoSeats();
        list[i].free -= count;
        try {
            pay();
        }
        catch (...) {
            list[i].free += count; // возврат
            throw;
        }
    }

    void show() {
        for (int i = 0; i < list.size(); i++) {
            std::cout << list[i].name
                << " осталось: "
                << list[i].free << std::endl;
        }
    }
};

int main() {
    System s;
    s.add("Rock", 100, 50);
    try {
        s.book("Rock", 3);
    }
    catch (MyException& e) {
        std::cout << "Ошибка: " << e.what() << std::endl;
    }
    s.show();

    return 0;
}
