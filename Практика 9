#include <iostream>
#include <fstream>
#include <string>

int main() {
    std::string name;
    std::cout << "Введите имя файла: ";
    std::cin >> name;
    std::ifstream file(name);
    if (!file) {
        std::cout << "Не удалось открыть файл\n";
        return 1;
    }
    int ok = 0;
    int bad = 0;
    double sum = 0;
    std::string s;
    while (std::getline(file, s)) {
        try {
            double x = std::stod(s);
            sum = sum + x;
            ok++;
        }
        catch (...) {
            std::cout << "Ошибка в строке: " << s << std::endl;
            bad++;
        }
    }
    std::cout << "\nРезультат:\n";
    std::cout << "Корректных строк: " << ok << std::endl;
    std::cout << "Ошибок: " << bad << std::endl;
    std::cout << "Сумма: " << sum << std::endl;
    file.close();

    return 0;
}

